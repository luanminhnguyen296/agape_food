								<path d="M29.4562 29.0944H30.5747V19.957H28.6221V28.2793C28.6221 28.7153 29.0012 29.0944 29.4562 29.0944Z" fill="#0068FF"></path>
							</svg>
							{ t.CtaBannerBtnZalo }
						</a>
						<a href="tel:0586758758" class="btn-banner-call">
							<i class="ph-bold ph-phone" style="font-size: 18px;"></i>
							{ t.CtaBannerBtnCall }
						</a>
					</div>
				</div>
				<div class="chef-banner-img">
					<img src={ templates.AssetURL("/static/images/cheefs.png") } alt="Đầu bếp Agape Food chuyên nghiệp"/>
				</div>
			</div>
		</section>
	}
}
