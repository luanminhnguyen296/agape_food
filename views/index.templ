		<section id="clients" class="section-padding bg-light" style="padding: 60px 0; border-top: 1px solid rgba(0,0,0,0.03); border-bottom: 1px solid rgba(0,0,0,0.03);">
			<div class="container">
				<div class="clients-logo-wrapper">
					<p class="clients-section-subtitle" aria-label={ t.ClientsTitle }>{ t.ClientsTitle }</p>
					<div class="clients-logo-grid">
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-mercedes-benz.png") } alt="Mercedes-Benz Vietnam" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-pnj.png") } alt="PNJ Production" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-knauf.png") } alt="KNAUF Việt Nam" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-golden-tiger.png") } alt="Golden Tiger Vietnam" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-hoptri-summit.png") } alt="Hoptri Summit" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-katsura.png") } alt="Katsura" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-dna-edge-polymer.png") } alt="D&amp;A Edge Polymer" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-nichirei.png") } alt="Nichirei TBA Logistics Vietnam" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-yoshikawa.png") } alt="Yoshikawa Logistics Vietnam" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-qtdt.png") } alt="Quốc Tế Đạt Thành" loading="lazy"/>
						</div>
						<div class="client-logo-item">
							<img src={ templates.AssetURL("/static/images/kh-kgl.png") } alt="KGL" loading="lazy"/>
						</div>
					</div>
				</div>
			</div>
		</section>
		<!-- Commitments & FAQ Section -->
		<section class="section-padding">
			<div class="container faq-grid">
				<!-- Left: Commitments -->
				<div>
					<h3 class="commit-title">{ t.CommitTitle }</h3>
					<div class="commit-list">
						<div class="commit-item">
							<span class="commit-icon"><i class="ph-bold ph-check"></i></span>
							<p>{ t.CommitItem1 }</p>
						</div>
						<div class="commit-item">
							<span class="commit-icon"><i class="ph-bold ph-check"></i></span>
							<p>{ t.CommitItem2 }</p>
						</div>
						<div class="commit-item">
							<span class="commit-icon"><i class="ph-bold ph-check"></i></span>
							<p>{ t.CommitItem3 }</p>
						</div>
						<div class="commit-item">
							<span class="commit-icon"><i class="ph-bold ph-check"></i></span>
							<p>{ t.CommitItem4 }</p>
						</div>
						<div class="commit-item">
							<span class="commit-icon"><i class="ph-bold ph-check"></i></span>
							<p>{ t.CommitItem5 }</p>
						</div>
						<div class="commit-item">
							<span class="commit-icon"><i class="ph-bold ph-check"></i></span>
							<p>{ t.CommitItem6 }</p>
						</div>
						<div class="commit-item">
							<span class="commit-icon"><i class="ph-bold ph-check"></i></span>
							<p>{ t.CommitItem7 }</p>
						</div>
					</div>
				</div>
				<!-- Right: Accordion FAQ -->
				<div>
					<h3 class="commit-title">{ t.FaqTitle }</h3>
					<div class="faq-accordion">
						<details class="faq-item" open>
							<summary class="faq-question">{ t.FaqQ1 }</summary>
							<div class="faq-answer">{ t.FaqA1 }</div>
						</details>
						<details class="faq-item">
							<summary class="faq-question">{ t.FaqQ2 }</summary>
							<div class="faq-answer">{ t.FaqA2 }</div>
						</details>
						<details class="faq-item">
							<summary class="faq-question">{ t.FaqQ3 }</summary>
							<div class="faq-answer">{ t.FaqA3 }</div>
						</details>
						<details class="faq-item">
							<summary class="faq-question">{ t.FaqQ4 }</summary>
							<div class="faq-answer">{ t.FaqA4 }</div>
						</details>
						<details class="faq-item">
							<summary class="faq-question">{ t.FaqQ5 }</summary>
							<div class="faq-answer">{ t.FaqA5 }</div>
						</details>
						<details class="faq-item">
							<summary class="faq-question">{ t.FaqQ6 }</summary>
							<div class="faq-answer">{ t.FaqA6 }</div>
						</details>
						<details class="faq-item">
							<summary class="faq-question">{ t.FaqQ7 }</summary>
							<div class="faq-answer">{ t.FaqA7 }</div>
						</details>
						<details class="faq-item">
							<summary class="faq-question">{ t.FaqQ8 }</summary>
							<div class="faq-answer">{ t.FaqA8 }</div>
						</details>
					</div>
				</div>
			</div>
		</section>
		<!-- CTA Bottom Banner -->
		<section id="contact" style="margin-top: 0;">
			<div class="chef-banner">
				<div class="chef-banner-food">
					<img src={ templates.AssetURL("/static/images/suat-com-mau-elements.png") } alt="Suất ăn Agape Food"/>
				</div>
				<div class="chef-banner-content">
					<h2>{ t.CtaBannerTitle }</h2>
					<div class="chef-banner-btns">
						<a href="https://zalo.me/0586758758" target="_blank" class="btn-banner-zalo">
							<svg width="20" height="20" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
