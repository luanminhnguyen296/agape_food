					</div>
					<!-- Right: Vertical Slider Showcase -->
					<div class="showcase-slider-wrapper">
						<div class="showcase-slider-container" id="showcaseSliderContainer">
							<div class="showcase-slider-track" id="showcaseSliderTrack">
								<div class="showcase-slide-item" onclick="openShowcaseModal('/static/images/bep-trung-tam.png', 'Bếp trung tâm')">
									<img src={ templates.AssetURL("/static/images/bep-trung-tam.png") } alt="Bếp trung tâm"/>
									<div class="showcase-slide-label">{ t.WhySlide1 }</div>
								</div>
								<div class="showcase-slide-item" onclick="openShowcaseModal('/static/images/khu-che-bien.png', 'Khu chế biến')">
									<img src={ templates.AssetURL("/static/images/khu-che-bien.png") } alt="Khu chế biến"/>
									<div class="showcase-slide-label">{ t.WhySlide2 }</div>
								</div>
								<div class="showcase-slide-item" onclick="openShowcaseModal('/static/images/canteen-nha-may.png', 'Canteen tại nhà máy')">
									<img src={ templates.AssetURL("/static/images/canteen-nha-may.png") } alt="Canteen tại nhà máy"/>
									<div class="showcase-slide-label">{ t.WhySlide3 }</div>
								</div>
								<div class="showcase-slide-item" onclick="openShowcaseModal('/static/images/car.png', 'Xe giao hàng')">
									<img src={ templates.AssetURL("/static/images/car.png") } alt="Xe giao hàng"/>
									<div class="showcase-slide-label">{ t.WhySlide4 }</div>
								</div>
								<div class="showcase-slide-item" onclick="openShowcaseModal('/static/images/giay-chung-nhan-an-toan.png', 'Hồ sơ & chứng nhận')">
									<img src={ templates.AssetURL("/static/images/giay-chung-nhan-an-toan.png") } alt="Hồ sơ chứng nhận"/>
									<div class="showcase-slide-label">{ t.WhySlide5 }</div>
								</div>
								<div class="showcase-slide-item" onclick="openShowcaseModal('/static/images/suat-an-mau.png', 'Suất ăn mẫu')">
									<img src={ templates.AssetURL("/static/images/suat-an-mau.png") } alt="Suất ăn mẫu"/>
									<div class="showcase-slide-label">{ t.WhySlide6 }</div>
								</div>
							</div>
							<div class="showcase-slider-dots" id="showcaseSliderDots">
								<span class="slider-dot active" onclick="setShowcaseSlide(0)"></span>
								<span class="slider-dot" onclick="setShowcaseSlide(1)"></span>
								<span class="slider-dot" onclick="setShowcaseSlide(2)"></span>
								<span class="slider-dot" onclick="setShowcaseSlide(3)"></span>
								<span class="slider-dot" onclick="setShowcaseSlide(4)"></span>
								<span class="slider-dot" onclick="setShowcaseSlide(5)"></span>
							</div>
							<!-- Navigation Controls -->
							<button class="showcase-slider-prev" onclick="moveShowcaseSlide(-1)" type="button" aria-label="Previous slide">
								<i class="ph-bold ph-caret-left"></i>
							</button>
							<button class="showcase-slider-next" onclick="moveShowcaseSlide(1)" type="button" aria-label="Next slide">
								<i class="ph-bold ph-caret-right"></i>
							</button>
						</div>
					</div>
					<!-- Detail Modal -->
					<div id="showcaseModal" class="showcase-modal" onclick="closeShowcaseModal()">
						<span class="showcase-modal-close" onclick="closeShowcaseModal()">&times;</span>
						<div class="showcase-modal-content" onclick="event.stopPropagation()">
							<img id="showcaseModalImg" src="" alt="Giấy chứng nhận / Quy trình"/>
							<div id="showcaseModalCaption" class="showcase-modal-caption"></div>
						</div>
					</div>
					<script>
						(function() {
							let currentSlide = 0;
							const totalSlides = 6;
							const track = document.getElementById('showcaseSliderTrack');
							const dots = document.querySelectorAll('#showcaseSliderDots .slider-dot');
							let autoplayInterval;

							function updateSlider() {
								if (!track) return;
								track.style.transform = 'translateX(-' + (currentSlide * 100) + '%)';
								dots.forEach((dot, index) => {
									if (index === currentSlide) {
										dot.classList.add('active');
									} else {
										dot.classList.remove('active');
									}
								});
							}

							window.setShowcaseSlide = function(index) {
								currentSlide = index;
								updateSlider();
								resetAutoplay();
							}

							window.moveShowcaseSlide = function(direction) {
								currentSlide = (currentSlide + direction + totalSlides) % totalSlides;
								updateSlider();
								resetAutoplay();
							}

							function nextSlide() {
								currentSlide = (currentSlide + 1) % totalSlides;
								updateSlider();
							}

							function startAutoplay() {
								autoplayInterval = setInterval(nextSlide, 3000);
							}

							function resetAutoplay() {
								clearInterval(autoplayInterval);
								startAutoplay();
							}

							const container = document.getElementById('showcaseSliderContainer');
							if (container) {
								container.addEventListener('mouseenter', () => clearInterval(autoplayInterval));
								container.addEventListener('mouseleave', startAutoplay);
							}

							const modal = document.getElementById('showcaseModal');
							const modalImg = document.getElementById('showcaseModalImg');
							const modalCaption = document.getElementById('showcaseModalCaption');

							window.openShowcaseModal = function(imgSrc, caption) {
								if (!modal || !modalImg || !modalCaption) return;
								modalImg.src = imgSrc;
								modalCaption.innerText = caption;
								modal.classList.add('active');
								document.body.style.overflow = 'hidden';
								clearInterval(autoplayInterval);
							}

							window.closeShowcaseModal = function() {
								if (!modal) return;
								modal.classList.remove('active');
								document.body.style.overflow = '';
								startAutoplay();
							}

							document.addEventListener('keydown', (e) => {
								if (e.key === 'Escape') {
									closeShowcaseModal();
								}
							});

							startAutoplay();
						})();
					</script>
				</div>
			</div>
		</section>
